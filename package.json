{
  "name": "algo-backtest-api",
  "version": "1.0.0",
  "description": "Options strategy backtesting engine with MongoDB + background workers",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "dev:worker": "ts-node-dev --respawn --transpile-only src/worker.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:worker": "node dist/worker.js",
    "test": "ts-node --transpile-only tests/run.ts",
    "test:unit": "ts-node --transpile-only tests/run.ts --unit",
    "test:integration": "ts-node --transpile-only tests/run.ts --integration",
    "lint": "eslint src --ext .ts",
    "indexes": "ts-node scripts/createIndexes.ts",
    "import": "ts-node scripts/importData.ts",
    "ws:example": "ts-node src/sdk/wsClient.ts",
    "sdk:examples": "ts-node src/sdk/examples.ts",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:build": "docker-compose build"
  },
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^8.1.0",
    "bull": "^4.12.2",
    "ioredis": "^5.3.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "zod": "^3.22.4",
    "date-fns": "^3.3.1",
    "uuid": "^9.0.1",
    "dotenv": "^16.4.1",
    "winston": "^3.11.0",
    "express-rate-limit": "^7.1.5",
    "compression": "^1.7.4",
    "@bull-board/api": "^5.18.0",
    "@bull-board/express": "^5.18.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/bull": "^4.10.0",
    "@types/cors": "^2.8.17",
    "@types/morgan": "^1.9.9",
    "@types/uuid": "^9.0.7",
    "@types/compression": "^1.7.5",
    "@types/ws": "^8.5.10",
    "@types/node": "^20.11.5",
    "typescript": "^5.3.3",
    "ts-node-dev": "^2.0.0",
    "ts-node": "^10.9.2",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.19.1",
    "@typescript-eslint/parser": "^6.19.1"
  }
}