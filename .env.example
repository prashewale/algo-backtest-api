# Server
PORT=3000
NODE_ENV=development

# MongoDB - collections named: option_chain_{instrument}_{year}
MONGODB_URI=mongodb://localhost:27017/algo_backtest

# Redis (for Bull queue)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Worker concurrency
BACKTEST_WORKER_CONCURRENCY=3
SIMULATOR_WORKER_CONCURRENCY=5

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Backtest config
MAX_CANDLES_PER_JOB=50000
MAX_STRATEGY_LEGS=10
